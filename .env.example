# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` — it is gitignored.

# --- Databases ---------------------------------------------------------------
# RDS Postgres (maintenance tables: assets, runs, daily-kWh). REQUIRED.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# Local SQLite (auth/login + app-internal data). Optional — defaults to ./factoryops.db
LOCAL_DATABASE_URL=sqlite:///./factoryops.db

# --- Auth / JWT --------------------------------------------------------------
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=8
DEV_BYPASS_TOKEN=dev-bypass-token

# --- Energy / cost tuning (optional; sensible defaults exist) ----------------
COST_PER_KWH=8.5
POWER_FACTOR=0.99
MAX_RUN_HOURS=16

# --- AWS S3 (proof-photo / image storage; optional unless using uploads) -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
